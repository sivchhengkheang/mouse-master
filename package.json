{
  "name": "mouse-master",
  "private": true,
  "version": "1.1.0",
  "scripts": {
    "dev": "vite",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "electron:start": "electron .",
    "electron:build": "vite build && electron-builder",
    "build:linux": "vite build && electron-builder --linux AppImage",
    "build:win": "vite build && electron-builder --win nsis",
    "build:all": "vite build && electron-builder --linux AppImage --win nsis"
  },
  "main": "electron/main.js",
  "author": "Koompi <info@koompi.com>",
  "description": "Mouse Master Game",
  "dependencies": {
    "@google/genai": "^1.35.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^34.0.0",
    "electron-builder": "^26.4.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^1.2.0",
    "wait-on": "^9.0.3",
    "workbox-window": "^7.4.0"
  },
  "build": {
    "appId": "com.koompi.mastermouse",
    "productName": "Mouse Master",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icon.png"
      }
    ],
    "icon": "build/icon.png",
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Game",
      "icon": "build/icon.png"
    },
    "pacman": {
      "depends": [],
      "artifactName": "${productName}-${version}.pkg.tar.zst"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.png"
    }
  }
}